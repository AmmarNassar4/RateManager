@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<section class="page-header">
    <h1>Login</h1>
    <p>Enter your username and password to access the system.</p>
</section>

<form asp-action="Login" method="post" class="card form-card auth-card">
    <div asp-validation-summary="ModelOnly" class="validation"></div>
    <input asp-for="ReturnUrl" type="hidden" />

    <label>
        Username
        <input asp-for="UserName" autocomplete="username" autofocus />
    </label>

    <label>
        Password
        <input asp-for="Password" type="password" autocomplete="current-password" />
    </label>

    <label class="checkbox-line">
        <input asp-for="RememberMe" type="checkbox" />
        Remember me
    </label>

    <div class="actions-row">
        <button type="submit" class="button primary">Login</button>
    </div>

   
</form>
