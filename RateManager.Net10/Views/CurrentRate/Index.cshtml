@model CurrentRateCalculatorViewModel
@{
    ViewData["Title"] = "Current Rate Calculator";
}

<style>
    .current-rate-layout {
        display: grid;
        grid-template-columns: minmax(360px, 0.9fr) minmax(420px, 1.1fr);
        gap: 1.25rem;
        align-items: start;
    }

    .current-rate-panel {
        position: sticky;
        top: 1rem;
    }

    .current-rate-fields {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }

    .current-rate-meal-group {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.85rem;
        padding: 1rem;
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 14px;
    }

    .current-rate-result-stack {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }

    @@media (max-width: 1000px) {
        .current-rate-layout {
            grid-template-columns: 1fr;
        }

        .current-rate-panel {
            position: static;
        }
    }
</style>

<section class="page-header">
    <h1>Current Rate Calculator</h1>
    <p>The total updates automatically using the latest saved daily rate for each night.</p>
</section>

<div class="current-rate-layout">
    <section class="card form-card current-rate-panel">
        <h2>Calculation Inputs</h2>

        <div class="current-rate-fields">
            <label>
                Rate Plan
                <select id="ratePlanId" asp-for="RatePlanId" asp-items="Model.RatePlans" data-auto-calc="true"></select>
            </label>

            <label>
                Room Type
                <select id="roomTypeId" asp-for="RoomTypeId" asp-items="Model.RoomTypes" data-auto-calc="true"></select>
            </label>

            <label>
                Start Date
                <input id="startDate" asp-for="StartDate" type="date" data-auto-calc="true" />
            </label>

            <label>
                Nights
                <input id="nights" asp-for="Nights" type="number" min="1" max="365" data-auto-calc="true" />
            </label>

            <label>
                Room Count
                <input id="roomCount" asp-for="RoomCount" type="number" min="1" data-auto-calc="true" />
            </label>
        </div>

        <hr />

        <div class="current-rate-fields">
            <div class="current-rate-meal-group">
                <label class="checkbox-line">
                    <input id="includeBreakfast" asp-for="IncludeBreakfast" type="checkbox" data-auto-calc="true" />
                    Include Breakfast
                </label>

                <label>
                    Adult Breakfast People (@Model.BreakfastPrice.ToString("0.###") per person per night)
                    <input id="breakfastPeople" asp-for="BreakfastPeople" type="number" min="0" data-auto-calc="true" />
                </label>

                <label>
                    Child Breakfast People (@Model.ChildBreakfastPrice.ToString("0.###") per child per night, @Model.ChildBreakfastDiscountPercent.ToString("0.##")% discount)
                    <input id="childBreakfastPeople" asp-for="ChildBreakfastPeople" type="number" min="0" data-auto-calc="true" />
                </label>
            </div>

            <div class="current-rate-meal-group">
                <label class="checkbox-line">
                    <input id="includeLunch" asp-for="IncludeLunch" type="checkbox" data-auto-calc="true" />
                    Include Lunch
                </label>

                <label>
                    Adult Lunch People (@Model.LunchPrice.ToString("0.###") per person per night)
                    <input id="lunchPeople" asp-for="LunchPeople" type="number" min="0" data-auto-calc="true" />
                </label>

                <label>
                    Child Lunch People (@Model.ChildLunchPrice.ToString("0.###") per child per night, @Model.ChildLunchDiscountPercent.ToString("0.##")% discount)
                    <input id="childLunchPeople" asp-for="ChildLunchPeople" type="number" min="0" data-auto-calc="true" />
                </label>
            </div>
        </div>

        <div class="hint">
            Tax is currently @Model.TaxPercent.ToString("0.####")% and can be changed from Settings.
            Child meal discounts can also be changed from Settings.
        </div>
    </section>

    <div class="current-rate-result-stack">
        <section class="card" id="resultCard" style="display:none;">
            <h2>Price Details</h2>
            <div class="stats-grid">
                <div class="stat-card"><span id="roomTotal">0</span><label>Room Total</label></div>
                <div class="stat-card"><span id="breakfastTotal">0</span><label>Adult Breakfast</label></div>
                <div class="stat-card"><span id="childBreakfastTotal">0</span><label>Child Breakfast</label></div>
                <div class="stat-card"><span id="lunchTotal">0</span><label>Adult Lunch</label></div>
                <div class="stat-card"><span id="childLunchTotal">0</span><label>Child Lunch</label></div>
                <div class="stat-card"><span id="mealTotal">0</span><label>Meals Total</label></div>
                <div class="stat-card"><span id="subtotal">0</span><label>Subtotal</label></div>
                <div class="stat-card"><span id="taxAmount">0</span><label id="taxLabel">Tax</label></div>
                <div class="stat-card"><span id="grandTotal">0</span><label>Grand Total</label></div>
            </div>

            <h3>Nightly Room Breakdown</h3>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Room Rate</th>
                        <th>Rooms</th>
                        <th>Room Total</th>
                    </tr>
                </thead>
                <tbody id="breakdownBody"></tbody>
            </table>
        </section>

        <section class="card" id="errorCard" style="display:none;">
            <h2>Unable to calculate</h2>
            <p id="errorMessage"></p>
        </section>
    </div>
</div>

@section Scripts {
<script>
    let calculateTimer = null;

    function money(value) {
        return Number(value || 0).toFixed(3);
    }

    function buildQuery() {
        const params = new URLSearchParams();
        params.set('ratePlanId', document.getElementById('ratePlanId').value);
        params.set('roomTypeId', document.getElementById('roomTypeId').value);
        params.set('startDate', document.getElementById('startDate').value);
        params.set('nights', document.getElementById('nights').value);
        params.set('roomCount', document.getElementById('roomCount').value);
        params.set('includeBreakfast', document.getElementById('includeBreakfast').checked);
        params.set('breakfastPeople', document.getElementById('breakfastPeople').value || '0');
        params.set('childBreakfastPeople', document.getElementById('childBreakfastPeople').value || '0');
        params.set('includeLunch', document.getElementById('includeLunch').checked);
        params.set('lunchPeople', document.getElementById('lunchPeople').value || '0');
        params.set('childLunchPeople', document.getElementById('childLunchPeople').value || '0');
        return params.toString();
    }

    function scheduleCalculation() {
        window.clearTimeout(calculateTimer);
        calculateTimer = window.setTimeout(calculateCurrentRate, 250);
    }

    async function calculateCurrentRate() {
        const startDate = document.getElementById('startDate').value;
        const nights = Number(document.getElementById('nights').value || 0);
        const roomCount = Number(document.getElementById('roomCount').value || 0);

        if (!startDate || nights <= 0 || roomCount <= 0) {
            document.getElementById('resultCard').style.display = 'none';
            return;
        }

        document.getElementById('errorCard').style.display = 'none';

        const response = await fetch(`/api/current-rate/calculate?${buildQuery()}`);
        const payload = await response.json();

        if (!response.ok) {
            document.getElementById('resultCard').style.display = 'none';
            document.getElementById('errorMessage').textContent = payload.message || 'Calculation failed.';
            document.getElementById('errorCard').style.display = 'block';
            return;
        }

        document.getElementById('roomTotal').textContent = money(payload.roomTotal);
        document.getElementById('breakfastTotal').textContent = money(payload.breakfastTotal);
        document.getElementById('childBreakfastTotal').textContent = money(payload.childBreakfastTotal);
        document.getElementById('lunchTotal').textContent = money(payload.lunchTotal);
        document.getElementById('childLunchTotal').textContent = money(payload.childLunchTotal);
        document.getElementById('mealTotal').textContent = money(payload.mealTotal);
        document.getElementById('subtotal').textContent = money(payload.subtotal);
        document.getElementById('taxAmount').textContent = money(payload.taxAmount);
        document.getElementById('taxLabel').textContent = `Tax (${Number(payload.taxPercent || 0).toFixed(2)}%)`;
        document.getElementById('grandTotal').textContent = money(payload.grandTotal);

        const body = document.getElementById('breakdownBody');
        body.innerHTML = '';
        for (const row of payload.nightsBreakdown) {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>${row.date}</td>
                <td>${money(row.roomRate)}</td>
                <td>${row.roomCount}</td>
                <td>${money(row.roomTotal)}</td>`;
            body.appendChild(tr);
        }

        document.getElementById('resultCard').style.display = 'block';
    }

    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('[data-auto-calc="true"]').forEach(element => {
            element.addEventListener('input', scheduleCalculation);
            element.addEventListener('change', scheduleCalculation);
        });

        scheduleCalculation();
    });
</script>
}