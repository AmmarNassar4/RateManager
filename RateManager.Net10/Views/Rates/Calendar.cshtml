@model CalendarViewModel
@{
    ViewData["Title"] = "Rates";
    var canEditRates = User.IsInRole("Admin");
}

<section class="page-header">
    <h1>Rates</h1>
    <p>
        Batch #@Model.Batch.RateGenerationBatchId - @Model.Batch.RatePlan?.RatePlanName
        (@Model.Batch.StartDate.ToString("yyyy-MM-dd") to @Model.Batch.EndDate.ToString("yyyy-MM-dd"))
    </p>
</section>

<div class="card toolbar-card">
    <input id="filterInput" placeholder="Search by room or date" oninput="filterRates()" />
    <span>Rows: @Model.Rates.Count</span>
</div>

<section class="card table-card">
    <table class="data-table" id="ratesTable">
        <thead>
            <tr>
                <th>Date</th>
                <th>Day</th>
                <th>Weekend</th>
                <th>Room Type</th>
                <th>Guests</th>
                <th>Rooms</th>
                <th>Base</th>
                <th>Adjustment %</th>
                <th>Calculated</th>
                @if (canEditRates)
                {
                    <th>Manual</th>
                }
                <th>Final</th>
                @if (canEditRates)
                {
                    <th>Save</th>
                }
            </tr>
        </thead>
        <tbody>
        @foreach (var rate in Model.Rates)
        {
            <tr data-search="@rate.RateDate.ToString("yyyy-MM-dd") @rate.DayName @rate.RoomType?.RoomName">
                <td>@rate.RateDate.ToString("yyyy-MM-dd")</td>
                <td>@rate.DayName</td>
                <td>@(rate.IsWeekend ? "Yes" : "No")</td>
                <td>@rate.RoomType?.RoomName</td>
                <td>@rate.GuestCount</td>
                <td>@rate.RoomCount</td>
                <td>@rate.BaseRate.ToString("0.###")</td>
                <td>@rate.TotalAdjustmentPercent.ToString("0.##")</td>
                <td>@rate.CalculatedRate.ToString("0.###")</td>
                @if (canEditRates)
                {
                    <td>
                        <input class="manual-rate" data-id="@rate.DailyRoomRateId" value="@(rate.ManualRate?.ToString("0.###") ?? string.Empty)" type="number" step="0.001" placeholder="Auto" />
                    </td>
                }
                <td class="final-rate @(rate.IsManualOverride ? "manual" : "")">@rate.FinalRate.ToString("0.###")</td>
                @if (canEditRates)
                {
                    <td><button type="button" class="button small" onclick="saveManualRate(@rate.DailyRoomRateId)">Save</button></td>
                }
            </tr>
        }
        </tbody>
    </table>
</section>

@if (canEditRates)
{
@section Scripts {
<script>
    async function saveManualRate(id) {
        const input = document.querySelector(`input[data-id='${id}']`);
        const value = input.value === '' ? null : Number(input.value);
        const response = await fetch('/Rates/UpdateManualRate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ dailyRoomRateId: id, manualRate: value, reason: 'Manual edit from calendar' })
        });

        if (!response.ok) {
            const error = await response.json();
            alert(error.message || 'Unable to save rate');
            return;
        }

        location.reload();
    }
</script>
}
}
