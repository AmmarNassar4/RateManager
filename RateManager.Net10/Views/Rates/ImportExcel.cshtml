@model ExcelImportViewModel
@{
    ViewData["Title"] = "Import Excel";
}

<section class="page-header">
    <h1>Import Rates from Excel</h1>
    <p>Select an Excel file to import both regular and discounted rates from the same file.</p>
</section>

<form asp-action="ImportExcel" method="post" enctype="multipart/form-data" class="card form-card">
    <div asp-validation-summary="ModelOnly" class="validation"></div>

    <div class="form-grid">
        <label>
            Regular Rate Plan
            <select asp-for="RatePlanId" asp-items="Model.RatePlans"></select>
        </label>

        <label>
            Discounted Rate Plan
            <select asp-for="DiscountRatePlanId" asp-items="Model.RatePlans">
                <option value="">Do not import discounted rates</option>
            </select>
        </label>

        <label>
            Default Discount %
            <input asp-for="DiscountPercent" type="number" min="0" max="100" step="0.01" />
        </label>

        <label>
            Start Date
            <input asp-for="StartDate" type="date" />
        </label>

        <label>
            Number of Days
            <input asp-for="NumberOfDays" type="number" min="1" max="365" />
        </label>

        <label>
            Default Guest Count
            <input asp-for="DefaultGuestCount" type="number" min="1" />
        </label>

        <label>
            Default Room Count
            <input asp-for="DefaultRoomCount" type="number" min="1" />
        </label>
    </div>

    <label>
        Excel File
        <input asp-for="ExcelFile" type="file" accept=".xlsx,.xlsm,.xltx,.xltm" />
        <span asp-validation-for="ExcelFile" class="validation"></span>
    </label>

    <details class="hint">
        <summary>Optional: use a server-side file path instead of uploading a file</summary>
        <label>
            Server-side Excel File Path
            <input asp-for="ExcelFilePath" placeholder="C:/Rates/Weekly Walk-In Rates.xlsx" />
        </label>
    </details>

    <label>
        Notes
        <input asp-for="Notes" />
    </label>

    <div class="hint">
        The system will try to detect the discounted section in the same file using words such as Discount, Family, Friends, or 25%.
        If no discounted section is found, the discounted rates will be calculated from regular rates using the default discount percentage.
    </div>

    <div class="actions-row">
        <button type="submit" class="button primary">Import</button>
        <a asp-controller="Home" asp-action="Index" class="button muted">Cancel</a>
    </div>
</form>