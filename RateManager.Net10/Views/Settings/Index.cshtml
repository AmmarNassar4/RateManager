@model SettingsViewModel
@{
    ViewData["Title"] = "الإعدادات";
}

<section class="page-header">
    <h1>الإعدادات</h1>
    <p>إعدادات واضحة مستقلة عن أسماء نظام الـ PMS القديم.</p>
</section>

<div class="settings-grid">
    <section class="card">
        <h2>أنواع الغرف</h2>
        <form asp-action="AddRoomType" method="post" class="inline-form">
            <input name="RoomCode" placeholder="Room Code" />
            <input name="RoomName" placeholder="Room Name" />
            <button class="button small" type="submit">إضافة</button>
        </form>
        <table class="data-table">
            <thead><tr><th>الكود</th><th>الاسم</th><th>نشط</th></tr></thead>
            <tbody>
            @foreach (var room in Model.RoomTypes)
            {
                <tr><td>@room.RoomCode</td><td>@room.RoomName</td><td>@room.IsActive</td></tr>
            }
            </tbody>
        </table>
    </section>

    <section class="card">
        <h2>خطط الأسعار</h2>
        <form asp-action="AddRatePlan" method="post" class="inline-form">
            <input name="RatePlanCode" placeholder="Rate Plan Code" />
            <input name="RatePlanName" placeholder="Rate Plan Name" />
            <input name="MealPlanCode" placeholder="Meal Plan" />
            <input name="CurrencyCode" value="SAR" placeholder="Currency" />
            <button class="button small" type="submit">إضافة</button>
        </form>
        <table class="data-table">
            <thead><tr><th>الكود</th><th>الاسم</th><th>Meal</th><th>Currency</th></tr></thead>
            <tbody>
            @foreach (var plan in Model.RatePlans)
            {
                <tr><td>@plan.RatePlanCode</td><td>@plan.RatePlanName</td><td>@plan.MealPlanCode</td><td>@plan.CurrencyCode</td></tr>
            }
            </tbody>
        </table>
    </section>

    <section class="card">
        <h2>المستخدمون</h2>
        <form asp-action="AddUser" method="post" class="inline-form">
            <input name="UserName" placeholder="Username" />
            <input name="Password" type="password" placeholder="Password" />
            <select name="Role">
                <option value="Viewer">Viewer - مشاهدة فقط</option>
                <option value="Admin">Admin - صلاحيات كاملة</option>
            </select>
            <button class="button small" type="submit">إضافة مستخدم</button>
        </form>
        <table class="data-table">
            <thead><tr><th>اسم المستخدم</th><th>الدور</th><th>نشط</th></tr></thead>
            <tbody>
            @foreach (var user in Model.Users)
            {
                <tr><td>@user.UserName</td><td>@user.Role</td><td>@user.IsActive</td></tr>
            }
            </tbody>
        </table>
    </section>

    <section class="card">
        <h2>أيام الـ Weekend</h2>
        <p class="hint">اختر الأيام التي تعتبر Weekend. نسبة الـ Weekend في شاشة الحساب ستطبق فقط على هذه الأيام.</p>
        <form asp-action="UpdateWeekendDays" method="post">
            <div class="checkbox-grid">
                @foreach (var day in Model.WeekendDays)
                {
                    <label class="checkbox-line">
                        <input type="checkbox" name="WeekendDays" value="@day.Weekday" checked="@(day.Enabled ? "checked" : null)" />
                        @day.Weekday
                    </label>
                }
            </div>
            <div class="actions-row">
                <button type="submit" class="button primary">حفظ أيام Weekend</button>
            </div>
        </form>
    </section>
</div>
