@model SettingsViewModel
@{
    ViewData["Title"] = "Settings";
}

<section class="page-header">
    <h1>Settings</h1>
    <p>Clear application settings independent from any legacy PMS table names.</p>
</section>

<div class="settings-grid">
    <section class="card">
        <h2>Room Types</h2>
        <form asp-action="AddRoomType" method="post" class="inline-form">
            <input name="RoomCode" placeholder="Room Code" />
            <input name="RoomName" placeholder="Room Name" />
            <button class="button small" type="submit">Add</button>
        </form>
        <table class="data-table">
            <thead><tr><th>Code</th><th>Name</th><th>Active</th></tr></thead>
            <tbody>
            @foreach (var room in Model.RoomTypes)
            {
                <tr><td>@room.RoomCode</td><td>@room.RoomName</td><td>@room.IsActive</td></tr>
            }
            </tbody>
        </table>
    </section>

    <section class="card">
        <h2>Rate Plans</h2>
        <form asp-action="AddRatePlan" method="post" class="inline-form">
            <input name="RatePlanCode" placeholder="Rate Plan Code" />
            <input name="RatePlanName" placeholder="Rate Plan Name" />
            <input name="MealPlanCode" placeholder="Meal Plan" />
            <input name="CurrencyCode" value="SAR" placeholder="Currency" />
            <button class="button small" type="submit">Add</button>
        </form>
        <table class="data-table">
            <thead><tr><th>Code</th><th>Name</th><th>Meal</th><th>Currency</th></tr></thead>
            <tbody>
            @foreach (var plan in Model.RatePlans)
            {
                <tr><td>@plan.RatePlanCode</td><td>@plan.RatePlanName</td><td>@plan.MealPlanCode</td><td>@plan.CurrencyCode</td></tr>
            }
            </tbody>
        </table>
    </section>

    <section class="card">
        <h2>Meal Prices</h2>
        <p class="hint">These fixed prices are used by the Current Rate Calculator.</p>
        <form asp-action="UpdateMealPrices" method="post" class="inline-form">
            <label>
                Breakfast Price
                <input name="BreakfastPrice" value="@Model.MealPrices.BreakfastPrice.ToString("0.###")" type="number" min="0" step="0.001" />
            </label>
            <label>
                Lunch Price
                <input name="LunchPrice" value="@Model.MealPrices.LunchPrice.ToString("0.###")" type="number" min="0" step="0.001" />
            </label>
            <button class="button small" type="submit">Save Meal Prices</button>
        </form>
    </section>

    <section class="card">
        <h2>Users</h2>
        <form asp-action="AddUser" method="post" class="inline-form">
            <input name="UserName" placeholder="Username" />
            <input name="Password" type="password" placeholder="Password" />
            <select name="Role">
                <option value="Viewer">Viewer - read only</option>
                <option value="Admin">Admin - full access</option>
            </select>
            <button class="button small" type="submit">Add User</button>
        </form>
        <table class="data-table">
            <thead><tr><th>Username</th><th>Role</th><th>Active</th></tr></thead>
            <tbody>
            @foreach (var user in Model.Users)
            {
                <tr><td>@user.UserName</td><td>@user.Role</td><td>@user.IsActive</td></tr>
            }
            </tbody>
        </table>
    </section>

    <section class="card">
        <h2>Weekend Days</h2>
        <p class="hint">Select which days should be treated as weekends. The weekend adjustment in the generation screen will only apply to these days.</p>
        <form asp-action="UpdateWeekendDays" method="post">
            <div class="checkbox-grid">
                @foreach (var day in Model.WeekendDays)
                {
                    <label class="checkbox-line">
                        <input type="checkbox" name="WeekendDays" value="@day.Weekday" checked="@(day.Enabled ? "checked" : null)" />
                        @day.Weekday
                    </label>
                }
            </div>
            <div class="actions-row">
                <button type="submit" class="button primary">Save Weekend Days</button>
            </div>
        </form>
    </section>
</div>
